# ══════════════════════════════════════════════════════════════════════════
# AI Interview Simulator — .gitignore
# ══════════════════════════════════════════════════════════════════════════

# ─── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
env/
.venv/
.env
ENV/

# ─── Node.js / Next.js ──────────────────────────────────────────────────
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── IDEs & Editors ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ─── OS Files ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Database ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── ML / Data Science ──────────────────────────────────────────────────
*.h5
*.hdf5
*.pkl
*.joblib
*.pt
*.pth
*.onnx
*.bin
*.safetensors
mlruns/
wandb/
lightning_logs/
checkpoints/
*.ckpt

# ─── Media / Audio ───────────────────────────────────────────────────────
*.wav
*.mp3
*.mp4
*.avi
*.mov
uploads/
recordings/

# ─── Logs ────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Coverage & Testing ─────────────────────────────────────────────────
htmlcov/
.coverage
.coverage.*
.tox/
.nox/
.pytest_cache/
coverage.xml
*.cover

# ─── Misc ────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
